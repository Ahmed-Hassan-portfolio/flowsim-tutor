# LLM Provider API Keys (set at least one)
# Get an Anthropic key: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Get an OpenAI key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Default LLM provider: "anthropic" or "openai"
# If unset, the connector picks the first provider with a valid key.
LLM_PROVIDER=anthropic

# Optional model overrides
# Anthropic: claude-sonnet-4-20250514, claude-3-5-sonnet-20241022, claude-3-5-haiku-20241022
# OpenAI:    gpt-4o, gpt-4-turbo, gpt-4
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o

# Optional: absolute path to server.py if the auto-detection doesn't work
# MCP_SERVER_PATH=
